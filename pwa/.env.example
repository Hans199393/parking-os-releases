# Parking MK PWA — zmienne środowiskowe
# Skopiuj ten plik jako .env i uzupełnij wartości

# Supabase — z Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://TWOJ_PROJEKT.supabase.co
VITE_SUPABASE_ANON_KEY=TWOJ_ANON_KEY

# Adres bazy HLS (komputer z Parking.OS na tej samej sieci WiFi)
# np. http://192.168.0.51:8888  (sprawdź IP: ipconfig → IPv4)
VITE_CAM_BASE_URL=http://192.168.0.51:8888
