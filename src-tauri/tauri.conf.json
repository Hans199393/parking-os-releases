{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Parking.OS",
  "version": "2026.1.5",
  "identifier": "com.klose.parking-os",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "splashscreen",
        "url": "splashscreen.html",
        "title": "Parking.OS",
        "width": 520,
        "height": 340,
        "resizable": false,
        "decorations": false,
        "center": true,
        "visible": true,
        "alwaysOnTop": true,
        "shadow": true
      },
      {
        "label": "main",
        "title": "Parking.OS",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self' https://*.supabase.co; connect-src 'self' https://*.supabase.co wss://*.supabase.co http://localhost:* ws://localhost:* https://api.github.com https://*.radio-browser.info https: http:; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: http://localhost:* https: http:; media-src 'self' blob: http://localhost:* rtsp: https: http:;"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": "v1Compatible",
    "resources": {
      "../rtsp-proxy/server.js": "rtsp-proxy/server.js",
      "../rtsp-proxy/package.json": "rtsp-proxy/package.json",
      "../rtsp-proxy/mediamtx.exe": "rtsp-proxy/mediamtx.exe",
      "../rtsp-proxy/mediamtx_auto.yml": "rtsp-proxy/mediamtx_auto.yml",
      "../rtsp-proxy/.env": "rtsp-proxy/.env",
      "../rtsp-proxy/node_modules/**/*": "rtsp-proxy/node_modules/",
      "bin/node.exe": "bin/node.exe",
      "bin/ffmpeg.exe": "bin/ffmpeg.exe",
      "default-settings.json": "default-settings.json"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "nsis": {
        "languages": ["Polish"],
        "startMenuFolder": "Parking.OS",
        "sidebarImage": "nsis-sidebar.bmp",
        "headerImage": "nsis-header.bmp",
        "installerHooks": "nsis-hooks.nsh"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDZFQjJFMDY4NThDMkFBRQpSV1N1S295RkJpN3JCaVZSd0ViYnNSMXVEeHRSVUEyVjlnTG12enFHaGZiUjhNaThGcVhQWVRZMAo=",
      "endpoints": [
        "https://github.com/Hans199393/parking-os-releases/releases/latest/download/latest.json"
      ],
      "dialog": true
    }
  }
}
