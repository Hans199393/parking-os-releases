{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "notification:default",
    "notification:allow-request-permission",
    "notification:allow-notify",
    "sql:default",
    "sql:allow-execute",
    "sql:allow-select",
    "sql:allow-load",
    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-mkdir",
    "fs:allow-read-dir",
    "fs:allow-remove",
    "store:default",
    "store:allow-get",
    "store:allow-set",
    "store:allow-load",
    "store:allow-save"
  ]
}
