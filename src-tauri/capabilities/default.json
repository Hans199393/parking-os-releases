{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window. FS operations restricted to AppData/parking-backups/.",
  "windows": ["main", "splashscreen"],
  "permissions": [
    "core:default",
    "opener:default",
    "notification:default",
    "notification:allow-request-permission",
    "notification:allow-notify",
    "sql:default",
    "sql:allow-execute",
    "sql:allow-select",
    "sql:allow-load",
    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-mkdir",
    "fs:allow-read-dir",
    "fs:allow-remove",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$APPDATA/parking-backups/**" },
        { "path": "$APPDATA/parking-backups" }
      ]
    },
    "store:default",
    "store:allow-get",
    "store:allow-set",
    "store:allow-load",
    "store:allow-save",
    "autostart:allow-enable",
    "autostart:allow-disable",
    "autostart:allow-is-enabled",
    "updater:default",
    "updater:allow-check",
    "updater:allow-download-and-install"
  ]
}

